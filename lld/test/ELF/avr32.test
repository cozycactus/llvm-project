# HEADER:      Format: elf32-avr32
# HEADER-NEXT: Arch: avr32
# HEADER:      ElfHeader {
# HEADER:        Class: 32-bit (0x1)
# HEADER-NEXT:   DataEncoding: BigEndian (0x2)
# HEADER:        Type: Executable (0x2)
# HEADER-NEXT:   Machine: EM_AVR32 (0xB9)

