--- !ELF
FileHeader:
  Class:   ELFCLASS32
  Data:    ELFDATA2MSB
  Type:    ET_REL
  Machine: EM_AVR32
Sections:
  - Name: .text
    Type: SHT_PROGBITS
    Flags: [ SHF_ALLOC, SHF_EXECINSTR ]
    Content: "0000"
Symbols:
  - Name: _start
    Section: .text
    Value: 0
    Binding: STB_GLOBAL

--- !ELF
FileHeader:
  Class:   ELFCLASS32
  Data:    ELFDATA2MSB
  Type:    ET_REL
  Machine: EM_AVR32
Sections:
  - Name: .text
    Type: SHT_PROGBITS
    Flags: [ SHF_ALLOC, SHF_EXECINSTR ]
    Content: "00000000000000000000000000000000"
  - Name: .rela.text
    Type: SHT_RELA
    Info: .text
    Relocations:
      - Offset: 0
        Symbol: abs32
        Type: R_AVR32_32
      - Offset: 4
        Symbol: abs16
        Type: R_AVR32_16
      - Offset: 6
        Symbol: abs8
        Type: R_AVR32_8
Symbols:
  - Name: _start
    Section: .text
    Value: 0
    Binding: STB_GLOBAL
  - Name: abs32
    Index: SHN_ABS
    Value: 0x12345678
    Binding: STB_GLOBAL
  - Name: abs16
    Index: SHN_ABS
    Value: 0x5678
    Binding: STB_GLOBAL
  - Name: abs8
    Index: SHN_ABS
    Value: 0x78
    Binding: STB_GLOBAL

