# RUN: llvm-readelf -S -s %t.stack-mem | FileCheck %s --check-prefix=STACK-MEM

# HEADER:      Format: elf32-avr32
# HEADER-NEXT: Arch: avr32
# HEADER:      ElfHeader {
# HEADER:        Class: 32-bit (0x1)
# HEADER-NEXT:   DataEncoding: BigEndian (0x2)
# HEADER:        Type: Executable (0x2)
# HEADER-NEXT:   Machine: EM_AVR32 (0xB9)
# STACK-DEFAULT: 00001000     0 NOTYPE  GLOBAL DEFAULT   ABS _stack_size
# STACK-OVERRIDE: 00002345     0 NOTYPE  GLOBAL DEFAULT   ABS _stack_size
# STACK-MEM: .stack            NOBITS          0000f000 {{[0-9a-f]+}} 001000 00  WA
# STACK-MEM-DAG: 00001000     0 NOTYPE  GLOBAL DEFAULT   ABS _stack_size
# STACK-MEM-DAG: 0000f000     0 NOTYPE  GLOBAL DEFAULT     {{[0-9]+}} _stack
# STACK-MEM-DAG: 00010000     0 NOTYPE  GLOBAL DEFAULT     {{[0-9]+}} _estack

