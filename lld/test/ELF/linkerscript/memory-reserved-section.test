# RUN: yaml2obj %s -o %t.o
# RUN: echo 'MEMORY { RAM (wxa!ri) : ORIGIN = 0x1000, LENGTH = 0x1000 } SECTIONS { .bss : { *(.bss) } >RAM .reserved ORIGIN(RAM) + 0x100 : { __reserved_start = .; . = 0x20; __reserved_end = .; } >RAM }' > %t.script
# RUN: ld.lld %t.o -T %t.script -o %t
# RUN: llvm-readelf -S -s -lW %t | FileCheck %s

# CHECK: .bss             NOBITS          0000000000001000 {{[0-9a-f]+}} 000004 00  WA
# CHECK: .reserved        NOBITS          0000000000001100 {{[0-9a-f]+}} 000020 00  WA
# CHECK-DAG: LOAD {{.*}} 0x0000000000001000 {{.*}} 0x000000 0x000004 RW
# CHECK-DAG: LOAD {{.*}} 0x0000000000001100 {{.*}} 0x000000 0x000020 RW
# CHECK-DAG: 0000000000001100     0 NOTYPE  GLOBAL DEFAULT     {{[0-9]+}} __reserved_start
# CHECK-DAG: 0000000000001120     0 NOTYPE  GLOBAL DEFAULT     {{[0-9]+}} __reserved_end

--- !ELF
FileHeader:
  Class: ELFCLASS64
  Data: ELFDATA2LSB
  Type: ET_REL
  Machine: EM_X86_64
Sections:
  - Name: .bss
    Type: SHT_NOBITS
    Flags: [ SHF_ALLOC, SHF_WRITE ]
    Size: 0x4
Symbols:
  - Name: bss_sym
    Section: .bss
    Binding: STB_GLOBAL
