# RUN: llc -mtriple=avr32 -run-pass=avr32-peephole -verify-machineinstrs %s -o - | FileCheck %s

--- |
  target triple = "avr32"

  define i32 @fold_redundant_cast(ptr %p) {
    ret i32 0
  }

  define i32 @fold_redundant_cast_single_pred(ptr %p) {
    ret i32 0
  }

  define i32 @keep_needed_cast(i32 %x) {
    ret i32 %x
  }

  define i32 @fold_compare_imm(i32 %x) {
    ret i32 %x
  }

  define i32 @fold_narrow_compare_imm(i32 %x) {
    ret i32 %x
  }

  define i32 @keep_signed_user_for_unsigned_cast(i32 %x) {
    ret i32 %x
  }
...
---
name:            fold_redundant_cast
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $r12

    ; CHECK-LABEL: name: fold_redundant_cast
    ; CHECK: $r8 = LD_UB_Disp3 $r12, 0
    ; CHECK-NEXT: CPri6 killed $r8, 0
    $r8 = LD_UB_Disp16 $r12, 0
    $r8 = CASTU_Bcg killed $r8, implicit-def dead $sreg
    CPri6 killed $r8, 0, implicit-def $sreg
    RETR12 implicit $r12
...
---
name:            fold_redundant_cast_single_pred
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $r12
    successors: %bb.1

    ; CHECK-LABEL: name: fold_redundant_cast_single_pred
    ; CHECK: $r8 = LD_UB_Disp3 $r12, 0
    ; CHECK: RJMPbb %bb.1
    $r8 = LD_UB_Disp16 $r12, 0
    BRALbb %bb.1

  bb.1:
    liveins: $r8, $r12

    ; CHECK: CPri6 killed $r8, 0
    $r8 = CASTU_Bcg killed $r8, implicit-def dead $sreg
    CPri6 killed $r8, 0, implicit-def $sreg
    RETR12 implicit $r12
...
---
name:            keep_needed_cast
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $r12

    ; CHECK-LABEL: name: keep_needed_cast
    ; CHECK: $r8 = MOVrr $r12
    ; CHECK-NEXT: $r8 = CASTU_Bcg killed $r8
    ; CHECK-NEXT: CPri6 killed $r8, 0
    $r8 = MOVrr $r12, implicit-def dead $sreg
    $r8 = CASTU_Bcg killed $r8, implicit-def dead $sreg
    CPri6 killed $r8, 0, implicit-def $sreg
    RETR12 implicit $r12
...
---
name:            fold_compare_imm
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $r12

    ; CHECK-LABEL: name: fold_compare_imm
    ; CHECK: $r8 = MOVri21 7
    ; CHECK-NEXT: CPrr $r12, killed $r8
    $r8 = MOVri21 7, implicit-def dead $sreg
    CPrr $r12, killed $r8, implicit-def $sreg
    RETR12 implicit $r12
...
---
name:            fold_narrow_compare_imm
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $r12
    successors: %bb.1

    ; CHECK-LABEL: name: fold_narrow_compare_imm
    ; CHECK: $r8 = MOVrr $r12
    ; CHECK-NEXT: $r8 = CASTU_Bcg killed $r8
    ; CHECK-NEXT: CP_Wri21 killed $r8, 32
    $r8 = MOVrr $r12, implicit-def dead $sreg
    $r8 = CASTU_Bcg killed $r8, implicit-def dead $sreg
    CP_Wri21 killed $r8, 32, implicit-def $sreg
    BRHIbb %bb.1, implicit $sreg
    RETR12 implicit $r12

  bb.1:
    liveins: $r12

    RETR12 implicit $r12
...
---
name:            keep_signed_user_for_unsigned_cast
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $r12
    successors: %bb.1

    ; CHECK-LABEL: name: keep_signed_user_for_unsigned_cast
    ; CHECK: $r8 = MOVrr $r12
    ; CHECK-NEXT: $r8 = CASTU_Bcg killed $r8
    ; CHECK-NEXT: CP_Wri21 killed $r8, 32
    $r8 = MOVrr $r12, implicit-def dead $sreg
    $r8 = CASTU_Bcg killed $r8, implicit-def dead $sreg
    CP_Wri21 killed $r8, 32, implicit-def $sreg
    BRGTbb %bb.1, implicit $sreg
    RETR12 implicit $r12

  bb.1:
    liveins: $r12

    RETR12 implicit $r12
...
