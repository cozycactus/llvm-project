# RUN: llc -mtriple=avr32 -filetype=obj -o %t.o %s
# RUN: llvm-readobj --hex-dump=.text %t.o | FileCheck %s

# Inline asm has a measurable size, so it should not make the LDA_W pool
# planner fall back to full 32-bit PC-relative loads for the whole function.
# CHECK:      Hex dump of section '.text':
# CHECK-NEXT: 0x00000000 00000000 48{{[0-9a-f][0-9a-f]}}

--- |
  target triple = "avr32"

  @g = external global i32

  define ptr @inline_asm_lda() {
    ret ptr @g
  }
...
---
name: inline_asm_lda
tracksRegLiveness: true
body: |
  bb.0:
    INLINEASM &".space 4", 1
    $r12 = LDA_W @g
    RETR12 implicit $r12
...
