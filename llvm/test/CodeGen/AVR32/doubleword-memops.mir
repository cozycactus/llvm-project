# RUN: llc -mtriple=avr32 -run-pass=avr32-peephole -verify-machineinstrs %s -o - | FileCheck %s

--- |
  target triple = "avr32"

  define i32 @fold_doubleword_load() {
    ret i32 0
  }

  define i32 @fold_doubleword_load_reversed() {
    ret i32 0
  }

  define i32 @fold_doubleword_store() {
    ret i32 0
  }

  define i32 @fold_doubleword_store_reversed() {
    ret i32 0
  }
...
---
name: fold_doubleword_load
tracksRegLiveness: true
body: |
  bb.0:
    liveins: $r12

    ; CHECK-LABEL: name: fold_doubleword_load
    ; CHECK: $r8 = LD_D_Disp16 $r12, 16, implicit-def $r9
    ; CHECK-NEXT: $r12 = ADDALrrr killed $r8, killed $r9
    $r9 = LD_W_Disp16 $r12, 16
    $r8 = LD_W_Disp16 $r12, 20
    $r12 = ADDALrrr killed $r8, killed $r9, implicit-def dead $sreg
    RETR12 implicit $r12
...
---
name: fold_doubleword_load_reversed
tracksRegLiveness: true
body: |
  bb.0:
    liveins: $r12

    ; CHECK-LABEL: name: fold_doubleword_load_reversed
    ; CHECK: $r10 = LD_D_Disp16 $r12, 32, implicit-def $r11
    ; CHECK-NEXT: $r12 = ADDALrrr killed $r10, killed $r11
    $r10 = LD_W_Disp16 $r12, 36
    $r11 = LD_W_Disp16 $r12, 32
    $r12 = ADDALrrr killed $r10, killed $r11, implicit-def dead $sreg
    RETR12 implicit $r12
...
---
name: fold_doubleword_store
tracksRegLiveness: true
body: |
  bb.0:
    liveins: $r8, $r9, $r12

    ; CHECK-LABEL: name: fold_doubleword_store
    ; CHECK: ST_D_Disp16 $r12, 48, killed $r8, implicit killed $r9
    ; CHECK-NEXT: RETR12
    ST_W_Disp16 $r12, 48, killed $r9
    ST_W_Disp16 $r12, 52, killed $r8
    RETR12 implicit $r12
...
---
name: fold_doubleword_store_reversed
tracksRegLiveness: true
body: |
  bb.0:
    liveins: $r10, $r11, $r12

    ; CHECK-LABEL: name: fold_doubleword_store_reversed
    ; CHECK: ST_D_Disp16 $r12, 64, killed $r10, implicit killed $r11
    ; CHECK-NEXT: RETR12
    ST_W_Disp16 $r12, 68, killed $r10
    ST_W_Disp16 $r12, 64, killed $r11
    RETR12 implicit $r12
...
