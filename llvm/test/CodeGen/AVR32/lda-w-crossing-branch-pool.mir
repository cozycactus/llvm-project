# RUN: llc -mtriple=avr32 -filetype=obj -o %t.o %s
# RUN: llvm-readobj --hex-dump=.text %t.o | FileCheck %s

# The end-of-function pool is too far for the early LDA_W pseudos to use
# compact lddpc encodings. A pool before bb.1 crosses the compact breq/rjmp,
# but both branches still remain in range after inserting the pool, so the
# splitter may place the pool there.
# CHECK:      0x00000000 d421484c 484b485a 4859c0b0 cf680000
# CHECK-NEXT: 0x00000010 00000000 00000000 00000000 00000000
# CHECK-NEXT: 0x00000020 e0a00000

--- |
  target triple = "avr32"

  declare void @side()

  @g0 = external global i32
  @g1 = external global i32
  @g2 = external global i32
  @g3 = external global i32

  define i32 @pool_cross_branch() {
    ret i32 0
  }
...
---
name: pool_cross_branch
tracksRegLiveness: true
body: |
  bb.0:
    liveins: $sreg

    $r12 = LDA_W @g0
    $r11 = LDA_W @g1
    $r10 = LDA_W @g2
    $r9 = LDA_W @g3
    BREQcbb %bb.1, implicit $sreg
    RJMPbb %bb.2

  bb.1:
    RCALLeCG @side, implicit-def $lr, implicit $sp, implicit-def $sp
    RCALLeCG @side, implicit-def $lr, implicit $sp, implicit-def $sp
    RCALLeCG @side, implicit-def $lr, implicit $sp, implicit-def $sp
    RCALLeCG @side, implicit-def $lr, implicit $sp, implicit-def $sp
    RCALLeCG @side, implicit-def $lr, implicit $sp, implicit-def $sp
