# RUN: yaml2obj %s -o %t.so
# RUN: llvm-objdump -R %t.so | FileCheck %s

# CHECK:      DYNAMIC RELOCATION RECORDS
# CHECK-NEXT: OFFSET   TYPE                     VALUE
# CHECK-NEXT: 00000030 R_AVR32_RELATIVE         *ABS*
# CHECK-NEXT: 00000034 R_AVR32_GLOB_DAT         data
# CHECK-NEXT: 00000038 R_AVR32_JMP_SLOT         func

--- !ELF
FileHeader:
  Class:   ELFCLASS32
  Data:    ELFDATA2MSB
  Type:    ET_DYN
  Machine: EM_AVR32
ProgramHeaders:
  - Type:     PT_LOAD
    FirstSec: .rel.dyn
    LastSec:  .dynamic
  - Type:     PT_DYNAMIC
    FirstSec: .dynamic
    LastSec:  .dynamic
Sections:
  - Name:         .rel.dyn
    Type:         SHT_REL
    Link:         .dynsym
    Flags:        [ SHF_ALLOC ]
    AddressAlign: 0x4
    Relocations:
      - Offset: 0x30
        Type:   R_AVR32_RELATIVE
      - Offset: 0x34
        Symbol: data
        Type:   R_AVR32_GLOB_DAT
  - Name:         .rel.plt
    Type:         SHT_REL
    Link:         .dynsym
    Flags:        [ SHF_ALLOC ]
    AddressAlign: 0x4
    Relocations:
      - Offset: 0x38
        Symbol: func
        Type:   R_AVR32_JMP_SLOT
  - Name:         .dynamic
    Type:         SHT_DYNAMIC
    Link:         .dynstr
    Flags:        [ SHF_ALLOC ]
    AddressAlign: 0x4
    Entries:
      - Tag:   DT_REL
        Value: 0
      - Tag:   DT_RELSZ
        Value: 16
      - Tag:   DT_RELENT
        Value: 8
      - Tag:   DT_JMPREL
        Value: 0x10
      - Tag:   DT_PLTREL
        Value: 17
      - Tag:   DT_PLTRELSZ
        Value: 8
      - Tag:   DT_NULL
        Value: 0
DynamicSymbols:
  - Name:    data
    Binding: STB_GLOBAL
  - Name:    func
    Type:    STT_FUNC
    Binding: STB_GLOBAL
