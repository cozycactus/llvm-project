TARGET_BUILTIN(__builtin_mtdr, "vUiUi", "n", "")
TARGET_BUILTIN(__builtin_tlbr, "v", "n", "")
TARGET_BUILTIN(__builtin_tlbs, "v", "n", "")
TARGET_BUILTIN(__builtin_tlbw, "v", "n", "")
